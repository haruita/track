generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String @id @default(cuid())

  username     String @unique
  email        String @unique

  passwordHash String

  role         Role @default(USER)

  avatarUrl    String?

  userMedias   UserMedia[]
}

model Media {
  id String @id @default(cuid())

  title String

  type String

  activity String
  status String

  progressTotal Int?
  progressUnit String

  description String?
  imageUrl String?

  userMedias UserMedia[]
}

model UserMedia {
  id              String @id @default(cuid())
  userId          String
  mediaId         String
  progressCurrent Int    @default(0)

  user   User  @relation(fields: [userId], references: [id])
  media  Media @relation(fields: [mediaId], references: [id])

  @@unique([userId, mediaId])
}
